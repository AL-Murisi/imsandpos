enum account_type {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  COST_OF_GOODS
}
enum TransactionType {
  RECEIPT // قبض (من عميل)
  PAYMENT // صرف (لمورد أو مصروف)

}

model InvoiceItem {
  id              String   @id @default(cuid())
  invoiceId       String   @map("invoice_id")
  productId       String   @map("product_id")
  companyId       String
  quantity        Decimal  @db.Decimal(12, 3)
  // السعر (يسمى UnitCost في الشراء و UnitPrice في البيع)
  price           Decimal  @db.Decimal(12, 2)
  totalPrice      Decimal  @db.Decimal(12, 2)
  unit     String  

  // في المبيعات نحتاج لخصم، في المشتريات قد لا نحتاجه دائماً
  discountAmount  Decimal? @default(0) @db.Decimal(12, 2)

  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}
model Invoice {
  id              String   @id @default(cuid())
  companyId       String   @map("company_id")
  invoiceNumber   String   @map("invoice_number")
  cashierId        String          @map("cashier_id")
  branchId        String?
  warehouseId     String?
  // التمييز بين البيع والشراء
  sale_type            InvoiceType @default(SALE) // SALE, PURCHASE, RETURN_SALE, RETURN_PURCHASE
  // الأطراف (اختياري حسب نوع الفاتورة)
  customerId      String?  @map("customer_id")
  customerName    String?  @map("customer_name")
  supplierId      String?  @map("supplier_id")
  //refundAmount Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal  @db.Decimal(12, 2)
  currencyCode    String?  @map("currency_code") @db.VarChar(3)
  exchangeRate    Decimal? @map("exchange_rate") @db.Decimal(18, 6)
  foreignAmount   Decimal? @map("foreign_amount") @db.Decimal(15, 2)
  baseAmount      Decimal? @map("base_amount") @db.Decimal(15, 2)
  amountPaid      Decimal  @default(0) @db.Decimal(12, 2)
  amountDue       Decimal  @default(0) @db.Decimal(12, 2)

  status          String    
   invoiceDate     DateTime @default(now()) @map("invoice_date")
  cashier      User?     @relation("UserSales", fields: [cashierId], references: [id])

  branch    points_of_sale? @relation(fields: [branchId], references: [id])
  warehouse Warehouse?     @relation(fields: [warehouseId], references: [id])
  customer         Customer?       @relation(fields: [customerId], references: [id])
  supplier      Supplier?       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  // العلاقات
  items           InvoiceItem[]
  transactions    FinancialTransaction[]
 
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@unique([companyId, invoiceNumber, sale_type])
  @@map("invoices")
}

enum InvoiceType {
  SALE
  PURCHASE
  RETURN_SALE
  RETURN_PURCHASE
}

model JournalHeader {
  id            String   @id @default(cuid())
  companyId     String   @map("company_id")
  entryNumber   String   @map("entry_number")
  description   String?
  branchId      String?
  referenceType String?  @map("reference_type")
  referenceId   String?  @map("reference_id")
  entryDate     DateTime @default(now()) @map("entry_date")
  status        String   @default("POSTED")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      points_of_sale? @relation(fields: [branchId], references: [id])
  createdUser User           @relation("JournalHeaderCreatedBy", fields: [createdBy], references: [id])
  lines       JournalLine[]

  @@unique([companyId, entryNumber])
  @@index([companyId])
  @@index([referenceType, referenceId])
  @@map("journal_headers")
}

model JournalLine {
  id            String   @id @default(cuid())
  headerId      String   @map("header_id")
  companyId     String   @map("company_id")
  accountId     String   @map("account_id")
  debit         Decimal  @default(0) @db.Decimal(15, 2)
  credit        Decimal  @default(0) @db.Decimal(15, 2)
  currencyCode  String?  @map("currency_code") @db.VarChar(3)
  foreignAmount Decimal? @map("foreign_amount") @db.Decimal(15, 2)
  exchangeRate  Decimal? @map("exchange_rate") @db.Decimal(18, 6)
  baseAmount    Decimal? @map("base_amount") @db.Decimal(15, 2)
  memo          String?

  header  JournalHeader @relation(fields: [headerId], references: [id], onDelete: Cascade)
  account accounts      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([accountId])
  @@map("journal_lines")
}


enum Roles { 
   
  admin
  cashier 
  manager_wh
  supplier
  accountant
  customer
} 
